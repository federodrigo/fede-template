---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<p>© {today.getFullYear()} Fede Rodrigo</p>

		<a
			href="https://www.linkedin.com/in/fede-rodrigo/"
			target="_blank"
			rel="noopener noreferrer"
		>
			LinkedIn
		</a>
	</div>
</footer>

<style>
	footer {
		margin-top: 80px;
		padding: 40px 24px;
		border-top: 1px solid #e2e8f0;
	}

	.footer-content {
		max-width: 920px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		color: #64748b;
		font-size: 0.95rem;
	}

	.footer-content p {
		margin: 0;
	}

	.footer-content a {
		color: #0f4c81;
		text-decoration: none;
		font-weight: 600;
	}

	.footer-content a:hover {
		color: #c1121f;
	}

	@media (max-width: 720px) {
		.footer-content {
			flex-direction: column;
			gap: 12px;
		}
	}
</style>
