---
const today = new Date();
---

<footer>
	<div class="footer-content">

		<div class="footer-left">
			<p>© {today.getFullYear()} Fede Rodrigo</p>
		</div>

		<div class="footer-right">
			<a
				href="mailto:contact@federodrigo.com"
			>
				Email
			</a>

			<span>•</span>

			<a
				href="https://www.linkedin.com/in/fede-rodrigo/"
				target="_blank"
				rel="noopener noreferrer"
			>
				LinkedIn
			</a>
		</div>

	</div>
</footer>

<style>
	footer {
		margin-top: 70px;
		padding: 28px 24px;
		border-top: 1px solid #d9e3f0;
	}

	.footer-content {
		max-width: 920px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.9rem;
		color: #64748b;
	}

	.footer-left p {
		margin: 0;
	}

	.footer-right {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.footer-right span {
		color: #94a3b8;
	}

	.footer-right a {
		color: #64748b;
		text-decoration: none;
		font-weight: 500;
		transition: color 0.15s ease;
	}

	.footer-right a:hover {
		color: #102a43;
	}

	@media (max-width: 720px) {
		.footer-content {
			flex-direction: column;
			gap: 10px;
		}
	}
</style>
