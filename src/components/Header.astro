---
const isSpanish = Astro.url.pathname.startsWith('/es');
const base = isSpanish ? '/es' : '';
---

<header class="site-header">
	<div class="header-inner">
		<a href={isSpanish ? "/es/" : "/"} class="brand">
			<span class="brand-name">Fede Rodrigo</span>
			<span class="brand-subtitle">CIO · Author</span>
		</a>

		<nav class="main-nav">
			<a href={`${base}/#about`}>About</a>
			<a href={`${base}/#leadership`}>The CIO Office</a>
			<a href={`${base}/#books`}>Books</a>
			<a href={`${base}/#contact`}>Contact</a>

			<span class="lang-switch">
				<a href="/">EN</a>
				<span>|</span>
				<a href="/es/">ES</a>
			</span>
		</nav>
	</div>
</header>
