---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/en/">Fede Rodrigo</a>

		<div class="nav-links">
			<HeaderLink href="/en/#about">About</HeaderLink>
			<HeaderLink href="/en/#books">Books</HeaderLink>
			<HeaderLink href="/en/#contact">Contact</HeaderLink>
			<a class="language" href="/es/">ES</a>
		</div>
	</nav>
</header>

<style>
	header {
		background: white;
		border-bottom: 1px solid rgba(15, 23, 42, 0.08);
	}

	nav {
		max-width: 1040px;
		margin: 0 auto;
		padding: 22px 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.brand {
		font-weight: 800;
		font-size: 1rem;
		color: #0f172a;
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 20px;
	}

	nav a {
		color: #334155;
		text-decoration: none;
		font-size: 0.95rem;
	}

	nav a:hover {
		color: #0f4c81;
	}

	.language {
		border: 1px solid #cbd5e1;
		border-radius: 999px;
		padding: 6px 12px;
		color: #0f4c81;
		font-weight: 700;
	}

	@media (max-width: 720px) {
		nav {
			padding: 18px 20px;
		}

		.nav-links {
			gap: 12px;
		}
	}
</style>
