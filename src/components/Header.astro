---
const isSpanish = Astro.url.pathname.startsWith('/es');
const base = isSpanish ? '/es' : '';
---

<header class="site-header">
	<div class="header-inner">
		<a href={isSpanish ? "/es/" : "/"} class="brand">
			<span class="brand-name">Fede Rodrigo</span>
			<span class="brand-subtitle">
				{isSpanish ? 'CIO · Autor' : 'CIO · Author'}
			</span>
		</a>

		<nav class="main-nav">
			<a href={`${base}/#about`}>
				{isSpanish ? 'Sobre mí' : 'About'}
			</a>

			<a href={`${base}/#leadership`}>
				{isSpanish ? 'La Oficina del CIO' : 'The CIO Office'}
			</a>
<a href={`${base}/#books`}>
	{isSpanish ? 'Libros' : 'Books'}
</a>

<a href={`${base}/#contact`} class="contact-link">
	{isSpanish ? 'Contacto' : 'Contact'}
</a>

<span class="lang-switch">
	<a href="/" class={isSpanish ? "" : "active"}>EN</a>
	<span>|</span>
	<a href="/es/" class={isSpanish ? "active" : ""}>ES</a>
</span>
					</nav>
	</div>
</header>
