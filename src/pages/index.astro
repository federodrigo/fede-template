---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Fede Rodrigo"
			description="Chief Information Officer, author, and technology leader."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Chief Information Officer</p>
				<h1>Fede Rodrigo</h1>
				<p class="lead">
					I turn technology into a growth engine for the business—not a cost center,
					not a religion, and definitely not a PowerPoint factory.
				</p>
				<p class="tags">Technology • Leadership • Institutions</p>
			</section>

			<section id="about">
				<h2>About</h2>

				<p>
					With over 25 years of global experience, I've led cloud migrations, ERP
					rollouts, IT/OT initiatives, and M&A integrations, always aligning technology
					with business outcomes, value creation, and real-world results.
				</p>

				<p>
					I build high-performing teams and deliver world-class service, because when
					IT forgets the business, it stops mattering.
				</p>

				<p>
					My work focuses on systems. In business, that means technology, leadership,
					execution, and value creation. In writing, it means exploring freedom,
					incentives, institutions, and why systems—technical or political—fail when
					they ignore reality.
				</p>
			</section>

			<section id="books">
				<h2>Books</h2>

				<h3>How to Become CIO and Succeed</h3>
				<p><em>People, Business, Strategy</em></p>

				<p>
					A practical guide for technology leaders who want to connect IT with business
					value, build strong teams, and succeed in the CIO role.
				</p>

				<p>
					<a href="https://www.amazon.com/dp/B0F8MVPN4Q" target="_blank">View on Amazon</a>
				</p>

				<h3>100 Years of Statism</h3>
				<p>
					An examination of the incentives, assumptions, and consequences that shaped a
					century of expanding government intervention.
				</p>

				<h3>Power, Tolerance and Legitimacy</h3>
				<p><em>A Theory of Minimal Tolerance</em></p>

				<p>
					A framework for evaluating when coercive power can be justified and where its
					legitimate boundaries lie.
				</p>
			</section>

			<section id="contact">
				<h2>Contact</h2>

				<p>
					Speaking engagements, podcasts, advisory work, and professional inquiries.
				</p>

				<p>
					<a href="https://www.linkedin.com/in/fede-rodrigo/" target="_blank">LinkedIn</a>
				</p>

				<p>
					<a href="mailto:frodrigo@gmail.com">frodrigo@gmail.com</a>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
