---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Fede Rodrigo"
			description="Chief Information Officer, author, and technology leader."
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
			
		<h1>
	<span class="accent">Technology</span> is never the<br />
	starting point
</h1>

				<p class="lead">
					People → Business → IT Strategy
				</p>

				</section>

			<section id="about">
				<h2>About</h2>

				<p>
					I am a Chief Information Officer with more than 25 years of global
					experience leading cloud migrations, ERP rollouts, IT/OT initiatives,
					M&A integrations, and technology transformation programs.
				</p>

				<p>
					My focus has always been the same: aligning technology with business
					outcomes, operational excellence, and long-term value creation.
				</p>

				<p>
					Beyond technology leadership, I write about freedom, incentives,
					institutions, and why systems—technical or political—fail when they
					ignore reality.
				</p>
			</section>

<section id="leadership">
	<h2>The CIO Office</h2>

		<div class="leadership-grid">
		<div class="leadership-card">
			<span>01</span>
			<h3>Executive Technology Leadership</h3>
			<p>Align technology decisions with business priorities, operating models, and long-term value creation.</p>
		</div>

		<div class="leadership-card">
			<span>02</span>
			<h3>Cloud & Digital Transformation</h3>
			<p>Lead modernization programs across cloud, infrastructure, applications, and enterprise platforms.</p>
		</div>

		<div class="leadership-card">
			<span>03</span>
			<h3>ERP & Enterprise Systems</h3>
			<p>Drive ERP and platform initiatives that improve visibility, execution, control, and decision-making.</p>
		</div>

		<div class="leadership-card">
			<span>04</span>
			<h3>M&A Technology Integration</h3>
			<p>Integrate systems, teams, vendors, processes, and data during acquisitions and organizational change.</p>
		</div>

		<div class="leadership-card">
			<span>05</span>
			<h3>IT / OT & Operational Technology</h3>
			<p>Connect technology leadership with operational realities, resilience, security, and business continuity.</p>
		</div>

		<div class="leadership-card">
			<span>06</span>
			<h3>Fractional CIO & Advisory</h3>
			<p>Support CEOs and executive teams that need experienced CIO-level direction, prioritization, and oversight.</p>
		</div>
	</div>
</section>
		<section id="books">
	<h2>Books</h2>

	<div class="books-grid">
		<div class="book-item">
			<img
				src="/images/cio-book-cover.jpg"
				alt="How to Become CIO and Succeed"
				class="book-cover"
			/>

			<div class="book-content">
				<h3>How to Become CIO and Succeed</h3>

				<p class="book-subtitle">People, Business, Strategy</p>

				<p class="book-description">
					A practical guide for technology leaders who want to connect IT
					with business value, build strong teams, and succeed in the CIO role.
				</p>
			</div>

			<p class="book-action">
				<a
					href="https://www.amazon.com/dp/B0F8MVPN4Q"
					target="_blank"
				>
					View on Amazon →
				</a>
			</p>
		</div>

		<div class="book-item">
			<img
				src="/images/poder-tolerancia-legitimidad.jpg"
				alt="Power, Tolerance, and Legitimacy"
				class="book-cover"
			/>

			<div class="book-content">
				<h3>Power, Tolerance, and Legitimacy</h3>

				<p class="book-subtitle">A Theory of Minimal Tolerance</p>

				<p class="book-description">
	A forthcoming book exploring legitimacy, coercion, institutional limits,
	and the conditions under which power can be considered tolerable.
</p>

<p class="book-ssrn">
	<a
		href="https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574"
		target="_blank"
	>
		Based on The Minimal Tolerance Theorem (SSRN) →
	</a>
</p>
		</div>
	</div>
</section>

<section id="contact">
	<h2>Contact</h2>

	<p>
		For executive leadership opportunities, board positions,
		fractional CIO engagements, podcasts, conferences,
		and speaking invitations:
	</p>

	<p>
		<a href="mailto:contact@federodrigo.com">
			contact@federodrigo.com
		</a>
	</p>

	<p>
		<a
			href="https://www.linkedin.com/in/fede-rodrigo/"
			target="_blank"
		>
			LinkedIn
		</a>
	</p>
</section>
			
		</main>




		<Footer />
	</body>
</html>
