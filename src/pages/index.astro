---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Fede Rodrigo"
			description="Chief Information Officer, author, and technology leader."
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>Fede Rodrigo</h1>

			<p>
				<strong>Chief Information Officer. Author. Technology Leader.</strong>
			</p>

			<p>
				I turn technology into a growth engine for the business — not a cost center,
				not a religion, and definitely not a PowerPoint factory.
			</p>

			<h2>About</h2>

			<p>
				With over 25 years of global experience, I’ve led cloud migrations, ERP
				rollouts, IT/OT initiatives, and M&A integrations, always aligning IT with
				business outcomes, value creation, and real-world results.
			</p>

			<p>
				I build high-performing teams and deliver world-class service, because when
				IT forgets the business, it stops mattering.
			</p>

			<p>
				Beyond technology leadership, my writing explores freedom, incentives,
				institutions, and why systems — technical or political — fail when they ignore
				reality.
			</p>

			<h2>Books</h2>

			<h3>How to Become CIO and Succeed</h3>
			<p><em>People, Business, Strategy</em></p>

			<p>
				A practical guide for technology leaders who want to connect IT with business
				value, build strong teams, and succeed in the CIO role.
			</p>

			<p>
				<a href="https://www.amazon.com/dp/B0F8MVPN4Q">View on Amazon</a>
			</p>

			<h2>Contact</h2>

			<p>
				For speaking, writing, or professional inquiries:
				<a href="mailto:frodrigo@gmail.com">frodrigo@gmail.com</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
