---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Fede Rodrigo"
			description="Chief Information Officer, author, and technology leader."
		/>
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<h1>Fede Rodrigo</h1>

				<p class="title">
					Chief Information Officer
				</p>

				<p class="lead">
					I turn technology into a growth engine for the business—not a cost center,
					not a religion, and definitely not a PowerPoint factory.
				</p>

				<p class="subtitle">
					Technology • Leadership • Business
				</p>
			</section>

			<section id="about">
				<h2>About</h2>

				<p>
					With more than 25 years of global experience, I've led cloud migrations,
					ERP rollouts, IT/OT initiatives, and M&A integrations, always aligning
					technology with business outcomes, value creation, and measurable results.
				</p>

				<p>
					I build high-performing teams and deliver world-class service, because
					when IT forgets the business, it stops mattering.
				</p>

				<p>
					Beyond technology leadership, I write about freedom, incentives,
					institutions, and the conditions under which power can be considered
					legitimate.
				</p>
			</section>

			<section id="books">
				<h2>Books</h2>

				<h3>How to Become CIO and Succeed</h3>
				<p><em>People, Business, Strategy</em></p>

				<p>
					A practical guide for technology leaders who want to connect IT with
					business value, build strong teams, and succeed in the CIO role.
				</p>

				<p>
					<a href="https://www.amazon.com/dp/B0F8MVPN4Q" target="_blank">
						View on Amazon
					</a>
				</p>

				<h3>Uruguay: 100 Years of Statism</h3>

				<p>
					An examination of the incentives, assumptions, and consequences that
					shaped a century of expanding government intervention.
				</p>

				<h3>Coming Soon: Power, Tolerance and Legitimacy</h3>

				<p>
					A framework for determining when coercive power can be justified and
					where its legitimate limits lie.
				</p>
			</section>

			<section id="contact">
				<h2>Contact</h2>

				<p>
					Speaking engagements, podcasts, advisory work, and professional inquiries.
				</p>

				<p>
					<a
						href="https://www.linkedin.com/in/fede-rodrigo/"
						target="_blank"
					>
						LinkedIn
					</a>
				</p>

				<p>
					<a href="mailto:frodrigo@gmail.com">
						frodrigo@gmail.com
					</a>
				</p>
			</section>
		</main>

		<Footer />
	</body>
</html>
