---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Fede Rodrigo"
			description="Chief Information Officer, author, and technology leader."
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<p class="eyebrow">Chief Information Officer</p>

				<h1>Technology is never the starting point.</h1>

				<p class="lead">
					People → Business → IT Strategy
				</p>

				<p class="hero-text">
					25+ years leading cloud transformation, ERP programs, IT/OT initiatives,
					M&A integrations, and global technology teams.
				</p>
			</section>

			<section id="about">
				<h2>About</h2>

				<p>
					I am a Chief Information Officer with more than 25 years of global
					experience leading cloud migrations, ERP rollouts, IT/OT initiatives,
					M&A integrations, and technology transformation programs.
				</p>

				<p>
					My focus has always been the same: aligning technology with business
					outcomes, operational excellence, and long-term value creation.
				</p>

				<p>
					Beyond technology leadership, my writing explores ideas about freedom, incentives, 
					institutions, and why systems—technical or political—fail when they ignore reality.
				</p>
			</section>

			<section id="books">
				<h2>Books</h2>

				<div class="book-card">
					<img
						src="/images/cio-book-cover.jpg"
						alt="How to Become CIO and Succeed"
						class="book-cover"
					/>

					<div class="book-info">
						<h3>How to Become CIO and Succeed</h3>

						<p>
							<em>People, Business, Strategy</em>
						</p>

						<p>
							A practical guide for technology leaders who want to connect
							IT with business value, build strong teams, and succeed in the
							CIO role.
						</p>

						<p>
							<a
								href="https://www.amazon.com/dp/B0F8MVPN4Q"
								target="_blank"
							>
								View on Amazon →
							</a>
						</p>
					</div>
				</div>

				<div class="book-card upcoming-book">
					<div class="book-info">
						<h3>Power, Tolerance y Legitimacy</h3>

						<p>
							<em>Coming Soon</em>
						</p>

						<p>
							A theory of minimal tolerance on power, legitimacy, coercion,
							and institutional limits.
						</p>
					</div>
				</div>
			</section>

			<section id="essays">
				<h2>Essays</h2>

				<div class="essay-card">
					<h3>The Minimal Tolerance Theorem</h3>

					<p>
						Free Riders, the State, and the "Institutional Technology of Last Resort"
					</p>

					<p>
						<a
							href="https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574&__cf_chl_f_tk=KI6qeMp4xqg2PSy_bRQlsroDKnKPxatIEerI2ZAgss8-1783422528-1.0.1.1-vujxYU4m1NBtPpwVFX.HlTLtXdzJ4ZwztW8j1rKouS8"
							target="_blank"
						>
							Read on SSRN →
						</a>
					</p>
				</div>
			</section>

			<section id="contact">
				<h2>Contact</h2>

				<p>
					Speaking engagements, podcasts, advisory work, and professional inquiries.
				</p>

				<p>
					<a
						href="https://www.linkedin.com/in/fede-rodrigo/"
						target="_blank"
					>
						LinkedIn
					</a>
				</p>

				<p>
					<a href="mailto:frodrigo@gmail.com">
						frodrigo@gmail.com
					</a>
				</p>
			</section>
		</main>

		<Footer />
	</body>
</html>
