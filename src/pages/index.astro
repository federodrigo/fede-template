---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Fede Rodrigo | CIO · Author"
			description="Chief Information Officer, author, and technology leader"
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<h1>
					Technology is <span class="accent">never</span><br />
					the starting point
				</h1>

				<div class="lead-principles">
					<div>People First</div>
					<div>Business Driven</div>
					<div>Technology Enabled</div>
				</div>
			</section>

		<section id="about">
	<h2>About</h2>

	<div class="about-layout">
		<div class="about-content">
	<p>
	I am a Chief Information Officer (CIO) with more than 25 years of
	experience leading transformations, cloud migrations, ERP
	implementations, IT/OT projects, and post-merger integration initiatives
</p>


<p>
	<strong>My approach is simple:</strong> align technology with business
	objectives. Stay hands-on, but always think strategically. Build a
	culture of service, operational excellence, and continuous improvement
</p>

			<p>
Beyond my work, I write about freedom, incentives, institutions,
	and why systems—technical or political—fail when they ignore reality
			</p>
		</div>

		<div class="about-photo-wrapper">
			<img
				src="/images/fede.png"
				alt="Fede Rodrigo, Chief Information Officer and author"
				class="about-photo"
			/>
		</div>
	</div>
</section>
			</section>

			<section id="leadership">
				<h2>The CIO Office</h2>

				<div class="leadership-grid">
					<div class="leadership-card">
						<h3>Executive Technology Leadership</h3>
						<p>
							Align technology decisions with business priorities, operating
							models, and long-term value creation
						</p>
					</div>

					<div class="leadership-card">
						<h3>Cloud & Digital Transformation</h3>
						<p>
							Lead modernization programs across cloud, infrastructure,
							applications, and enterprise platforms
						</p>
					</div>

					<div class="leadership-card">
						<h3>ERP & Enterprise Systems</h3>
						<p>
							Drive ERP and platform initiatives that improve visibility,
							execution, control, and decision-making
						</p>
					</div>

					<div class="leadership-card">
						<h3>M&A Technology Integration</h3>
						<p>
							Integrate systems, teams, vendors, processes, and data during
							acquisitions and organizational change
						</p>
					</div>

					<div class="leadership-card">
						<h3>IT / OT & Operational Technology</h3>
						<p>
							Connect technology leadership with operational realities,
							resilience, security, and business continuity
						</p>
					</div>

					<div class="leadership-card">
						<h3>Fractional CIO & Advisory</h3>
						<p>
							Support CEOs and executive teams that need experienced CIO-level
							direction, prioritization, and oversight
						</p>
					</div>
				</div>
			</section>

			<section id="books">
				<h2>Books</h2>

				<div class="books-grid">
					<div class="book-item">
						<img
							src="/images/cio-book-cover.jpg"
							alt="How to Become CIO and Succeed"
							class="book-cover"
						/>

						<div class="book-content">
							<h3>How to Become CIO and Succeed</h3>

							<p class="book-subtitle">People, Business, Strategy</p>

							<p class="book-description">
								A practical guide for technology leaders who want to connect IT
								with business value, build strong teams, and succeed in the CIO
								role
							</p>
						</div>

						<p class="book-action">
							<a
								href="https://www.amazon.com/dp/B0F8MVPN4Q"
								target="_blank"
							>
								View on Amazon →
							</a>
						</p>
					</div>

					<div class="book-item">
						<img
							src="/images/book-cover.jpg"
							alt="A Theory of Minimal Tolerance"
							class="book-cover"
						/>

						<div class="book-content">
							<h3>A Theory of Minimal Tolerance</h3>

							<p class="book-subtitle">A Theory of Minimal Tolerance</p>

							<p class="book-description">
								A forthcoming book exploring legitimacy, coercion,
								institutional limits, and the conditions under which power can
								be considered tolerable
							</p>

							<p class="book-ssrn">
								<a
									href="https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574"
									target="_blank"
								>
									Based on The Minimal Tolerance Theorem (SSRN) →
								</a>
							</p>
						</div>
					</div>
				</div>
			</section>

<section id="contact" class="contact-section">
	<h2>Contact</h2>

	<p class="contact-intro">
		For executive leadership opportunities, speaking engagements,
		podcasts, media inquiries, or general questions,
		please reach out directly
	</p>

	<div class="contact-links">
		<div class="contact-item">
			<span class="contact-icon">✉</span>

			<div>
				<div class="contact-label">EMAIL</div>

				<a href="mailto:contact@federodrigo.com">
					contact@federodrigo.com
				</a>
			</div>
		</div>

		<div class="contact-item">
			<span class="contact-icon">in</span>

			<div>
				<div class="contact-label">LINKEDIN</div>

				<a
					href="https://www.linkedin.com/in/fede-rodrigo/"
					target="_blank"
				>
					linkedin.com/in/fede-rodrigo
				</a>
			</div>
		</div>

		<div class="contact-item">
			<span class="contact-icon">→</span>

			<div>
				<div class="contact-label">RESPONSE</div>

				<p>
					I personally review all inquiries and respond when appropriate
				</p>
			</div>
		</div>
	</div>
</section>


		</main>

		<Footer />
	</body>
</html>
