---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title="Fede Rodrigo"
			description="Chief Information Officer, autor y líder en tecnología."
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">

				<h1>
					La tecnología <span class="accent">nunca</span><br />
					es el punto de partida
				</h1>

			<div class="lead-principles">
	<div>Personas primero</div>
	<div>Impulsado por el negocio</div>
	<div>Habilitado por la tecnología</div>
</div>

			</section>

			<section id="about">
				<h2>Sobre mí</h2>

				<p>
					Soy Chief Information Officer con más de 25 años de experiencia
					internacional liderando migraciones a la nube, implementaciones ERP,
					iniciativas IT/OT, integraciones de adquisiciones y programas de
					transformación tecnológica.
				</p>

				<p>
					Mi enfoque siempre ha sido el mismo: alinear la tecnología con los
					resultados del negocio, la excelencia operativa y la creación de valor
					a largo plazo.
				</p>

				<p>
					Más allá del liderazgo tecnológico, escribo sobre libertad,
					incentivos, instituciones y por qué los sistemas —técnicos o políticos—
					fracasan cuando ignoran la realidad.
				</p>
			</section>

			<section id="leadership">
				<h2>La Oficina del CIO</h2>

				<div class="leadership-grid">
					<div class="leadership-card">
						<h3>Liderazgo Ejecutivo en Tecnología</h3>
						<p>
							Alinear las decisiones tecnológicas con las prioridades del negocio,
							los modelos operativos y la creación de valor a largo plazo.
						</p>
					</div>

					<div class="leadership-card">
						<h3>Transformación Digital y Cloud</h3>
						<p>
							Liderar programas de modernización en infraestructura,
							aplicaciones, plataformas empresariales y servicios cloud.
						</p>
					</div>

					<div class="leadership-card">
						<h3>ERP y Sistemas Empresariales</h3>
						<p>
							Impulsar iniciativas ERP y plataformas que mejoren la visibilidad,
							la ejecución, el control y la toma de decisiones.
						</p>
					</div>

					<div class="leadership-card">
						<h3>Integración Tecnológica en Fusiones y Adquisiciones</h3>
						<p>
							Integrar sistemas, equipos, proveedores, procesos y datos durante
							adquisiciones y cambios organizacionales.
						</p>
					</div>

					<div class="leadership-card">
						<h3>IT / OT y Tecnología Operacional</h3>
						<p>
							Conectar el liderazgo tecnológico con la realidad operativa,
							la resiliencia, la seguridad y la continuidad del negocio.
						</p>
					</div>

					<div class="leadership-card">
						<h3>CIO Fraccional y Asesoría Ejecutiva</h3>
						<p>
							Acompañar a CEOs y equipos ejecutivos que necesitan dirección,
							priorización y supervisión a nivel CIO.
						</p>
					</div>
				</div>
			</section>

			<section id="books">
				<h2>Libros</h2>

				<div class="books-grid">
					<div class="book-item">
						<img
							src="/images/cio-book-cover.jpg"
							alt="Cómo Convertirse en CIO y Tener Éxito"
							class="book-cover"
						/>

						<div class="book-content">
							<h3>Cómo Convertirse en CIO y Tener Éxito</h3>

							<p class="book-subtitle">
								Personas, Negocio, Estrategia
							</p>

							<p class="book-description">
								Una guía práctica para líderes tecnológicos que buscan conectar TI
								con valor de negocio, construir equipos sólidos y tener éxito en el
								rol de CIO.
							</p>
						</div>

						<p class="book-action">
							<a
								href="https://www.amazon.com/dp/B0F8MVPN4Q"
								target="_blank"
							>
								Ver en Amazon →
							</a>
						</p>
					</div>

					<div class="book-item">
						<img
							src="/images/poder-tolerancia-legitimidad.jpg"
							alt="Poder, Tolerancia y Legitimidad"
							class="book-cover"
						/>

						<div class="book-content">
							<h3>Poder, Tolerancia y Legitimidad</h3>

							<p class="book-subtitle">
								Una Teoría de la Tolerancia Mínima
							</p>

							<p class="book-description">
								Un próximo libro que explora la legitimidad, la coerción,
								los límites institucionales y las condiciones bajo las cuales
								el poder puede considerarse tolerable.
							</p>

							<p class="book-ssrn">
								<a
									href="https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574"
									target="_blank"
								>
									Basado en el Teorema de la Tolerancia Mínima (SSRN) →
								</a>
							</p>
						</div>
					</div>
				</div>
			</section>

			<section id="contact" class="contact-section">
				<h2>Contacto</h2>

				<p>
					Para oportunidades de liderazgo ejecutivo, posiciones en directorios,
					servicios de CIO fraccional, podcasts, conferencias e invitaciones
					para disertar:
				</p>

				<p>
					<a href="mailto:contact@federodrigo.com">
						contact@federodrigo.com
					</a>
				</p>

				<p>
					<a
						href="https://www.linkedin.com/in/fede-rodrigo/"
						target="_blank"
					>
						LinkedIn
					</a>
				</p>
			</section>

		</main>

		<Footer />
	</body>
</html>
