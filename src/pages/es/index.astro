---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title="Fede Rodrigo | CIO · Autor"
			description="Chief Information Officer, autor y líder tecnológico"
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<h1>
					La tecnología <span class="accent">nunca</span><br />
					es el punto de partida
				</h1>

				<div class="lead-principles">
					<div>Primero las personas</div>
					<div>Impulsados por el negocio</div>
					<div>Habilitados por la tecnología</div>
				</div>
			</section>

			<section id="about">
				<h2>Sobre mí</h2>

				<div class="about-layout">
					<div class="about-content">
<p>
	Soy Gerente de Tecnología (CIO) con más de 25 años de experiencia
	internacional liderando programas de transformación, migraciones a la
	nube, implementaciones de ERP, proyectos IT/OT y la integración de
	empresas adquiridas
</p>
<p>
	<strong>Mi enfoque es simple:</strong> alinear la tecnología con los
	objetivos del negocio. Mantenerme involucrado en la ejecución, sin perder
	la visión estratégica. Construir una cultura de servicio, excelencia
	operativa y mejora continua
</p>

						<p>
							Más allá de mi trabajo, escribo sobre libertad, incentivos,
							instituciones y por qué los sistemas —técnicos o políticos—
							fracasan cuando ignoran la realidad
						</p>
					</div>

					<div class="about-photo-wrapper">
						<img
							src="/images/fede.png"
							alt="Fede Rodrigo, Gerente de Tecnología y autor"
							class="about-photo"
						/>
					</div>
				</div>
			</section>

			<section id="leadership">
				<h2>La Oficina del CIO</h2>

				<div class="leadership-grid">
					<div class="leadership-card">
						<h3>Liderazgo tecnológico ejecutivo</h3>

						<p>
							Alinear las decisiones tecnológicas con las prioridades del
							negocio, los modelos operativos y la creación de valor a largo
							plazo
						</p>
					</div>

					<div class="leadership-card">
						<h3>Nube y transformación digital</h3>

						<p>
							Liderar programas de modernización de infraestructura,
							aplicaciones, plataformas empresariales y servicios en la nube
						</p>
					</div>

					<div class="leadership-card">
						<h3>ERP y sistemas empresariales</h3>

						<p>
							Impulsar iniciativas de ERP y plataformas que mejoren la
							visibilidad, la ejecución, el control y la toma de decisiones
						</p>
					</div>

					<div class="leadership-card">
						<h3>Integración tecnológica de adquisiciones</h3>

						<p>
							Integrar sistemas, equipos, proveedores, procesos y datos durante
							adquisiciones y procesos de cambio organizacional
						</p>
					</div>

					<div class="leadership-card">
						<h3>IT/OT y tecnología operacional</h3>

						<p>
							Conectar el liderazgo tecnológico con la realidad operativa, la
							resiliencia, la seguridad y la continuidad del negocio
						</p>
					</div>

					<div class="leadership-card">
						<h3>CIO fraccional y asesoramiento</h3>

						<p>
							Apoyar a CEOs y equipos ejecutivos que necesitan dirección,
							priorización y supervisión con experiencia de nivel CIO
						</p>
					</div>
				</div>
			</section>

			<section id="books">
				<h2>Libros</h2>

				<div class="books-grid">
					<div class="book-item">
						<img
							src="/images/cio-book-cover.jpg"
							alt="How to Become CIO and Succeed"
							class="book-cover"
						/>

						<div class="book-content">
							<h3>How to Become CIO and Succeed</h3>

							<p class="book-subtitle">
								Personas, negocio y estrategia
							</p>

							<p class="book-description">
								Una guía práctica para líderes tecnológicos que buscan conectar
								la tecnología con el valor del negocio, desarrollar equipos
								sólidos y tener éxito en el rol de CIO
							</p>
						</div>

						<p class="book-action">
							<a
								href="https://www.amazon.com/dp/B0F8MVPN4Q"
								target="_blank"
							>
								Ver en Amazon →
							</a>
						</p>
					</div>

					<div class="book-item">
						<img
							src="/images/book-cover.jpg"
							alt="A Theory of Minimal Tolerance"
							class="book-cover"
						/>

						<div class="book-content">
							<h3>A Theory of Minimal Tolerance</h3>

							<p class="book-subtitle">
								Una teoría de la tolerancia mínima
							</p>

							<p class="book-description">
								Un próximo libro sobre legitimidad, coerción, límites
								institucionales y las condiciones bajo las cuales el ejercicio
								del poder puede considerarse tolerable
							</p>

							<p class="book-ssrn">
								<a
									href="https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5984574"
									target="_blank"
								>
									Basado en The Minimal Tolerance Theorem (SSRN) →
								</a>
							</p>
						</div>
					</div>
				</div>
			</section>

			<section id="contact" class="contact-section">
				<h2>Contacto</h2>

				<p class="contact-intro">
					Para oportunidades de liderazgo ejecutivo, conferencias, podcasts,
					consultas de prensa o preguntas generales, podés contactarme
					directamente
				</p>

				<div class="contact-links">
					<div class="contact-item">
						<span class="contact-icon">✉</span>

						<div>
							<div class="contact-label">EMAIL</div>

							<a href="mailto:contact@federodrigo.com">
								contact@federodrigo.com
							</a>
						</div>
					</div>

					<div class="contact-item">
						<span class="contact-icon">in</span>

						<div>
							<div class="contact-label">LINKEDIN</div>

							<a
								href="https://www.linkedin.com/in/fede-rodrigo/"
								target="_blank"
							>
								linkedin.com/in/fede-rodrigo
							</a>
						</div>
					</div>

					<div class="contact-item">
						<span class="contact-icon">→</span>

						<div>
							<div class="contact-label">RESPUESTA</div>

							<p>
								Reviso personalmente todas las consultas y respondo cuando
								corresponde
							</p>
						</div>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
